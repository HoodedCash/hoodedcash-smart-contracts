# Copy to .env and fill in before deploying. Never commit the real file.

# Deployer key. Must hold ETH on Robinhood Chain to pay gas.
PRIVATE_KEY=0x...

# Compliance authority that attests KYC results onchain (see HoodedRegistry).
COMPLIANCE_AUTHORITY=0x...

# USDG (Global Dollar), the primary settlement stablecoin on Robinhood Chain.
# This is the asset the ConfidentialToken wraps and the default agent spend token.
USDG_ADDRESS=0x...

# Deployed Groth16 verifier for confidential transfers. Leave unset to deploy
# the bundled MockTransferVerifier during bring-up, then rotate to the real one.
TRANSFER_VERIFIER_ADDRESS=

# $HOODED governance token. Holding and staking it lowers protocol fees. The
# deploy script deploys HoodedStaking + FeeController against this token and
# wires fee routing. Leave HOODED_ADDRESS or TREASURY unset to deploy with fees
# switched off.
HOODED_ADDRESS=0xd125f8f710b052b66ae5ef2113957c83d25a7777
# Address that receives protocol fees.
TREASURY=

# Blockscout API key for `forge verify-contract` (may be left blank on Blockscout).
BLOCKSCOUT_API_KEY=
